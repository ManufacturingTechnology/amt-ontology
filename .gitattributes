# Treat generated dist/ artefacts as binary so git's autocrlf / line-ending
# normalization never modifies them. Without this, on Windows checkouts the
# CSVs round-trip through LF<->CRLF and `make dist; git diff --exit-code dist/`
# reports a 100%-changed diff that's actually pure line-ending noise.
dist/*.csv binary
dist/*.owl binary

# resources/*.csv are the source-of-truth baselines that
# tests/test_csv_export.py compares against. Python's csv.writer emits CRLF
# (RFC 4180), so we force these files to CRLF on every platform's working
# tree -- otherwise an Ubuntu CI checkout gets LF (because git stored them
# normalised), the live exporter produces CRLF, and the byte-level baseline
# test fails with "no row-level differences" (i.e. pure line-ending drift).
resources/*.csv text eol=crlf

# Ontology / shapes / templates / static assets -- let git use platform LF
# normally on these text files.
*.ttl text eol=lf
*.owl text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Python source: LF on all platforms.
*.py text eol=lf
