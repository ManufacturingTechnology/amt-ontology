@prefix sh:       <http://www.w3.org/ns/shacl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix amtmeta:  <http://ontology.amt.org/meta#> .
@prefix cmns-cls: <https://www.omg.org/spec/Commons/Classifiers/> .

##
## SHACL shapes for AMT user-view ontologies.
##
## These shapes are validated against the *union* of a view file
## (exhibitor_view / visitor_view / ind_view) and its source ontology
## (pc / pc / ind). That union is what app.validation.validate_view loads
## and what the tests in tests/test_shacl_shapes.py exercise.
##
## Each shape is paired with a focused sh:message so that, when a constraint
## is violated, the pyshacl report names the offending node and explains
## *why* the assertion failed — useful in CI logs.
##

##
## Every amtmeta:Collection must:
##   - carry at least one rdfs:label   (the UI uses it for the Major / Sub
##     row labels and as a sort key)
##   - reference only IRIs via amtmeta:groups (no blank nodes, no literals)
##
amtmeta:CollectionShape
    a sh:NodeShape ;
    sh:targetClass amtmeta:Collection ;

    sh:property [
        sh:path     rdfs:label ;
        sh:minCount 1 ;
        sh:message  "Every amtmeta:Collection must have at least one rdfs:label." ;
    ] ;

    sh:property [
        sh:path     amtmeta:groups ;
        sh:nodeKind sh:IRI ;
        sh:message  "amtmeta:groups targets must be IRIs (no blank nodes or literals)." ;
    ] .


##
## Every target of amtmeta:groups must resolve to a known kind of entity in
## the union (view + source) graph. The four legitimate shapes are:
##
##   * another amtmeta:Collection in the view  (Sub Category branch)
##   * an amtmeta:Collection from the source ontology
##     (catalog-grouping / catalog-residual Collections in pc.ttl —
##     e.g. LaserTechnologyCollection)
##   * an owl:Class in the source ontology
##     (a leaf Product Category — e.g. pc:LacqueringSystem)
##   * a cmns-cls:Classifier in the source ontology
##     (a leaf Industry classifier — e.g. ind:Aerospace; added in
##     v0.2.0 when Industry adopted the OMG Commons pattern, see
##     im.ttl D32 / ind.ttl D1).
##
## Anything else (a dangling URI, a typo'd reference, a value that exists
## only as a string somewhere) trips this shape.
##
amtmeta:GroupsTargetShape
    a sh:NodeShape ;
    sh:targetObjectsOf amtmeta:groups ;
    sh:or (
        [ sh:class amtmeta:Collection ]
        [ sh:class owl:Class ]
        [ sh:class cmns-cls:Classifier ]
    ) ;
    sh:message "amtmeta:groups targets must be amtmeta:Collection, owl:Class, or cmns-cls:Classifier in the source ontology." .


##
## Every view file declares amtmeta:viewOf at least once, pointing at the
## ontology IRI it is a view of. The shape only fires on subjects that
## already have a viewOf assertion (because SHACL has no portable way to
## target "the ontology IRI of the loaded data graph"), but it does catch
## blank-node or literal viewOf objects.
##
amtmeta:ViewDeclarationShape
    a sh:NodeShape ;
    sh:targetSubjectsOf amtmeta:viewOf ;
    sh:property [
        sh:path     amtmeta:viewOf ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message  "amtmeta:viewOf must point at an ontology IRI." ;
    ] .
