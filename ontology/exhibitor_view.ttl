################################################################################
# SHACL constraints
################################################################################
# Two-part composition (logical AND), applied to the topic the ProductCategory
# aspect externally depends on (im.ttl D24: ProductCategory is gufo:Kind ⊑
# gufo:ExtrinsicMode with materialized instances; the topic is reached via
# gufo:externallyDependsOn one hop further than hasProductCategory):
#   (i)  bucket membership — topic must be transitively reachable via
#        amtmeta:groups+ from an exhibitor_view bucket;
#   (ii) catalog-grade — topic must satisfy amtmeta:CatalogValueShape, i.e.
#        carry skos:prefLabel (entities without prefLabel are abstract
#        scaffolding and not assertable as data values).

exhibitor_view:ExhibitorOfferingShape a sh:NodeShape ;
    rdfs:label "Exhibitor Product Category Constraint" ;
    sh:targetClass im:ExhibitorRecord ;

    # (i) View-scoped bucket membership — dereferenced through the materialized
    # ProductCategory aspect to its externallyDependsOn topic.
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Product category topic '{?value}' is not in the exhibitor view's allowed set." ;
        sh:select """
            PREFIX im:      <http://ontology.amt.org/im#>
            PREFIX gufo:    <http://purl.org/nemo/gufo#>
            PREFIX amtmeta: <http://ontology.amt.org/meta#>
            PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
            SELECT $this ?value WHERE {
                $this    im:hasProductCategory     ?offering .
                ?offering gufo:externallyDependsOn ?value .
                FILTER NOT EXISTS {
                    ?bucket amtmeta:groups+ ?value ;
                            rdfs:isDefinedBy <http://ontology.amt.org/views/exhibitor> .
                }
            }
        """ ;
    ] ;

    # (ii) Catalog-grade — CatalogValueShape applied to the topic reached via
    # the property path (hasProductCategory, then externallyDependsOn).
    sh:property [
        sh:path ( im:hasProductCategory gufo:externallyDependsOn ) ;
        sh:node amtmeta:CatalogValueShape ;
    ] .


################################################################################
# RESOLVED DECISIONS
################################################################################
# D1 - View-side sub-property exhibitor_view:hasProductCategory declared as
#      rdfs:subPropertyOf im:hasProductCategory with tighter domain
#      (im:ExhibitorRecord). As of v0.2.2, retained purely as a provenance/
#      channel tag — typing and membership are owned by im:hasProductCategory's
#      range (im:ProductCategory) and exhibitor_view:ExhibitorOfferingShape
#      respectively.
# D2 - SHACL shape retargeted from im:Exhibitor to im:ExhibitorRecord
#      (im:hasInterest/im:hasProductCategory moved off the role onto the
#      registration record in im.ttl v0.2)
# D3 - Catalog-value rule delegated to amtmeta:CatalogValueShape (v0.2.2).
#      View shape now enforces (bucket membership) ∧ (catalog-grade) on
#      values of im:hasProductCategory via composition: sh:sparql for the
#      first, sh:property + sh:node for the second. Implication: view-side
#      sub-buckets (e.g. exhibitor_view:AutomatedSystemsCells) that lack
#      skos:prefLabel will no longer pass as data values — they are pure
#      organizational scaffolding, queryable as groupers but not assertable.
#      Per im.ttl D16, im:hasProductCategory's OWL range im:ProductCategory
#      is a role-mixin marker, not a membership enumeration. (Superseded
#      in part by D4 — ProductCategory is no longer a role-mixin marker.)
# D4 - SHACL rewritten to dereference ProductCategory one hop further (im.ttl
#      D24). im:hasProductCategory now points at materialized im:ProductCategory
#      instances (gufo:Kind ⊑ gufo:ExtrinsicMode), and the validated topic
#      sits on gufo:externallyDependsOn. Both halves of the shape were updated:
#        - sh:sparql adds the ?offering gufo:externallyDependsOn ?value hop
#          before checking bucket membership;
#        - sh:property uses a property-path sh:path ( im:hasProductCategory
#          gufo:externallyDependsOn ) so CatalogValueShape validates the
#          topic rather than the ProductCategory aspect.
#      Data shape change: ExhibitorRecord rows now reference ProductCategory
#      IRIs, not pc: topic IRIs directly. Pipelines must materialize
#      ProductCategory instances with gufo:inheresIn (Company) and
#      gufo:externallyDependsOn (pc: topic) at registration time.
#
################################################################################
# OPEN FLAGS (for human review)
################################################################################
# F1 - If any view-side sub-bucket should be assertable as a data value, give
#      it a skos:prefLabel. Current sub-buckets carry rdfs:label only.
