@prefix amtmeta: <http://ontology.amt.org/meta#> .
@prefix gufo:    <http://purl.org/nemo/gufo#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

<http://ontology.amt.org/meta>
    a owl:Ontology ;
    owl:imports <http://purl.org/nemo/gufo> ;
    rdfs:label "AMT Metadata Vocabulary" ;
    owl:versionInfo  "0.1.0" ;
    owl:versionIRI   <http://ontology.amt.org/meta/0.1.0> ;

    amtmeta:releaseDate     "2026-05-13"^^xsd:date ;
    amtmeta:scopeSummary    "Initial release -- governance vocabulary, status individuals, release-log properties, catalog-value SHACL shape." ;
    amtmeta:releaseOwner    "Shaurabh" ;
    amtmeta:approvalStatus  amtmeta:Draft ;
    amtmeta:gitTag          "v0.1.0" ;
    amtmeta:githubRelease   <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.1.0> ;
    amtmeta:releaseNotes    <https://github.com/ManufacturingTechnology/amt-ontology/releases/tag/v0.1.0> ;
    amtmeta:relatedDocumentation <https://amtonline.sharepoint.com/sites/governance/Shared%20Documents/Taxonomy%20Change%20Process.docx> .

amtmeta:Vocabulary       a owl:Class ; rdfs:subClassOf owl:Ontology ; rdfs:label "Vocabulary" .
amtmeta:Taxonomy         a owl:Class ; rdfs:subClassOf amtmeta:Vocabulary ; rdfs:label "Taxonomy" .
amtmeta:UserView         a owl:Class ; rdfs:subClassOf amtmeta:Vocabulary ; rdfs:label "User View" .
amtmeta:InformationModel a owl:Class ; rdfs:subClassOf amtmeta:Vocabulary ; rdfs:label "Information Model" .
amtmeta:Collection       a owl:Class ; rdfs:subClassOf gufo:Category ; rdfs:label "Collection" .
amtmeta:Status           a owl:Class ; rdfs:label "Status" .

amtmeta:Active      a amtmeta:Status ; rdfs:label "Active" ; skos:prefLabel "Approved" ;
    rdfs:comment "In-use / signed-off taxonomy state." .
amtmeta:Draft       a amtmeta:Status ; rdfs:label "Draft" ; skos:prefLabel "Draft" .
amtmeta:UnderReview a amtmeta:Status ; rdfs:label "Under Review" ; skos:prefLabel "Pending Review" ;
    rdfs:comment "Review in progress." .
amtmeta:Deprecated  a amtmeta:Status ; rdfs:label "Deprecated" ; skos:prefLabel "Deprecated" .

amtmeta:groups a owl:ObjectProperty ; rdfs:domain amtmeta:Collection ; rdfs:label "groups" .

amtmeta:viewOf   a owl:AnnotationProperty ; rdfs:label "view of" .
amtmeta:scopedBy a owl:AnnotationProperty ; rdfs:label "scoped by" ;
    rdfs:comment "Ties an IM concept to the user view that defines its runtime membership via SHACL." .

amtmeta:status              a owl:AnnotationProperty ; rdfs:label "status" .
amtmeta:taxonomyOwner       a owl:AnnotationProperty ; rdfs:label "taxonomy owner" .
amtmeta:governedBy          a owl:AnnotationProperty ; rdfs:label "governed by" .
amtmeta:consumedBy          a owl:AnnotationProperty ; rdfs:label "consumed by" .
amtmeta:technicalSteward    a owl:AnnotationProperty ; rdfs:label "technical steward" .
amtmeta:relatedProduct      a owl:AnnotationProperty ; rdfs:label "related product" .
amtmeta:relatedSystem       a owl:AnnotationProperty ; rdfs:label "related system" .
amtmeta:nextReviewDate      a owl:AnnotationProperty ; rdfs:label "next review date" .
amtmeta:nextReviewNote      a owl:AnnotationProperty ; rdfs:label "next review note" .
amtmeta:useCase             a owl:AnnotationProperty ; rdfs:label "use case" .
amtmeta:notes               a owl:AnnotationProperty ; rdfs:label "notes" ;
    rdfs:comment "Free-form editorial / governance notes." .
amtmeta:relatedDocumentation a owl:AnnotationProperty ; rdfs:label "related documentation" ;
    rdfs:comment "IRI pointer to external documentation." .

amtmeta:releaseDate    a owl:AnnotationProperty ; rdfs:label "release date" ;
    rdfs:comment "Calendar date the current ontology release was tagged." .
amtmeta:scopeSummary   a owl:AnnotationProperty ; rdfs:label "scope summary" .
amtmeta:releaseOwner   a owl:AnnotationProperty ; rdfs:label "release owner" .
amtmeta:approvalStatus a owl:AnnotationProperty ; rdfs:label "approval status" .
amtmeta:releaseNotes   a owl:AnnotationProperty ; rdfs:label "release notes" .
amtmeta:githubRelease  a owl:AnnotationProperty ; rdfs:label "GitHub release" .
amtmeta:gitTag         a owl:AnnotationProperty ; rdfs:label "git tag" .

amtmeta:CatalogValueShape a sh:NodeShape ;
    rdfs:label "Catalog Value Constraint" ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:message "Value is abstract (lacks skos:prefLabel) and cannot be used as a catalog value."
    ] .
