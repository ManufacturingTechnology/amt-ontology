@prefix visitor_view: <http://ontology.amt.org/views/visitor#> .
@prefix pc:           <http://ontology.amt.org/product-categories#> .
@prefix im:           <http://ontology.amt.org/im#> .
@prefix amtmeta:      <http://ontology.amt.org/meta#> .
@prefix gufo:         <http://purl.org/nemo/gufo#> .
@prefix sh:           <http://www.w3.org/ns/shacl#> .
@prefix owl:          <http://www.w3.org/2002/07/owl#> .
@prefix rdf:          <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:         <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:          <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms:      <http://purl.org/dc/terms/> .

<http://ontology.amt.org/views/visitor>
    a owl:Ontology, amtmeta:UserView ;
    owl:imports <http://ontology.amt.org/meta>,
                <http://ontology.amt.org/product-categories>,
                <http://ontology.amt.org/im> ;

    dcterms:title    "Visitor View of Product Categories" ;
    owl:versionInfo  "0.1.0" ;
    amtmeta:viewOf   <http://ontology.amt.org/product-categories> ;

    amtmeta:status              amtmeta:Active ;
    amtmeta:taxonomyOwner       "Chris Downs" ;
    amtmeta:governedBy          "Allison", "Ryan", "Downs" ;
    amtmeta:consumedBy          "Kristin", "Mark K", "Jess", "Allison",
                                "Downs", "Alka", "Kalesh" ;
    amtmeta:technicalSteward    "Shaurabh" ;

    amtmeta:relatedProduct
        "IMTS (visitor reg and exhibitor categories/showrooms)",
        "Passport",
        "Media Sponsorships (media kit)" ;

    amtmeta:relatedSystem
        "Maritz",
        "Hubspot",
        "Data warehouse",
        "Passport",
        "Exhibitor Space Application (linked at major category)" ;

    amtmeta:nextReviewDate      "2026-06-01"^^xsd:date ;
    amtmeta:nextReviewNote      "Need to discuss for Space Application." ;

    rdfs:seeAlso                "Taxonomy Change Process.docx" ;

    amtmeta:useCase
        "Marketing uses this for targeted marketing",
        "Passport uses this as a filter to create lists",
        "IMTS uses this as a demographic field for visitor registration",
        "IMTS uses this in post-show reporting",
        "IMTS uses this to create exhibitor product categories" .


################################################################################
# View-defined sub-property
################################################################################
# Channel/provenance tag — declares that an assertion was made through the
# visitor view. Not load-bearing for typing or validation (those live on
# im:hasInterest's range and the SHACL shape below). Retain for downstream
# tools that want to distinguish view-channel from raw IM-channel assertions.

visitor_view:hasInterest a owl:ObjectProperty ;
    rdfs:subPropertyOf im:hasInterest ;
    rdfs:domain im:VisitorRecord ;
    rdfs:label "has interest" ;
    rdfs:comment "Provenance channel for assertions made via the visitor view. Typing and membership are inherited from im:hasInterest and enforced by visitor_view:VisitorInterestShape." .


