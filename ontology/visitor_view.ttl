################################################################################
# SHACL constraints
################################################################################
# Two-part composition (logical AND), applied to the topic the Interest aspect
# externally depends on (im.ttl D24: Interest is gufo:Kind ⊑ gufo:ExtrinsicMode
# with materialized instances; the topic is reached via
# gufo:externallyDependsOn one hop further than hasInterest):
#   (i)  bucket membership — topic must be transitively reachable via
#        amtmeta:groups+ from a visitor_view bucket;
#   (ii) catalog-grade — topic must satisfy amtmeta:CatalogValueShape, i.e.
#        carry skos:prefLabel (entities without prefLabel are abstract
#        scaffolding and not assertable as data values).

visitor_view:VisitorInterestShape a sh:NodeShape ;
    rdfs:label "Visitor Interest Constraint" ;
    sh:targetClass im:VisitorRecord ;

    # (i) View-scoped bucket membership — dereferenced through the materialized
    # Interest aspect to its externallyDependsOn topic.
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Interest topic '{?value}' is not in the visitor view's allowed set." ;
        sh:select """
            PREFIX im:      <http://ontology.amt.org/im#>
            PREFIX gufo:    <http://purl.org/nemo/gufo#>
            PREFIX amtmeta: <http://ontology.amt.org/meta#>
            PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
            SELECT $this ?value WHERE {
                $this    im:hasInterest            ?interest .
                ?interest gufo:externallyDependsOn ?value .
                FILTER NOT EXISTS {
                    ?bucket amtmeta:groups+ ?value ;
                            rdfs:isDefinedBy <http://ontology.amt.org/views/visitor> .
                }
            }
        """ ;
    ] ;

    # (ii) Catalog-grade — CatalogValueShape applied to the topic reached via
    # the property path (hasInterest, then externallyDependsOn).
    sh:property [
        sh:path ( im:hasInterest gufo:externallyDependsOn ) ;
        sh:node amtmeta:CatalogValueShape ;
    ] .


################################################################################
# RESOLVED DECISIONS
################################################################################
# D1 - View-side sub-property visitor_view:hasInterest declared as
#      rdfs:subPropertyOf im:hasInterest with tighter domain
#      (im:VisitorRecord). As of v0.2.2, retained purely as a provenance/
#      channel tag — typing and membership are owned by im:hasInterest's
#      range (im:Interest) and visitor_view:VisitorInterestShape respectively.
# D2 - SHACL shape retargeted from im:Visitor to im:VisitorRecord
#      (im:hasInterest/im:hasProductCategory moved off the role onto the
#      registration record in im.ttl v0.2)
# D3 - Catalog-value rule delegated to amtmeta:CatalogValueShape (v0.2.2).
#      View shape now enforces (bucket membership) ∧ (catalog-grade) on
#      values of im:hasInterest via composition: sh:sparql for the first,
#      sh:property + sh:node for the second. Implication: view-side
#      sub-buckets (e.g. visitor_view:AutomatedSystemsCells) that lack
#      skos:prefLabel will no longer pass as data values — they are pure
#      organizational scaffolding, queryable as groupers but not assertable.
#      Per im.ttl D16, im:hasInterest's OWL range im:Interest is a
#      role-mixin marker, not a membership enumeration. (Superseded in part
#      by D4 — Interest is no longer a role-mixin marker.)
# D4 - SHACL rewritten to dereference Interest one hop further (im.ttl D24).
#      im:hasInterest now points at materialized im:Interest instances
#      (gufo:Kind ⊑ gufo:ExtrinsicMode), and the validated topic sits on
#      gufo:externallyDependsOn. Both halves of the shape were updated:
#        - sh:sparql adds the ?interest gufo:externallyDependsOn ?value hop
#          before checking bucket membership;
#        - sh:property uses a property-path sh:path ( im:hasInterest
#          gufo:externallyDependsOn ) so CatalogValueShape validates the
#          topic rather than the Interest aspect.
#      Data shape change: VisitorRecord rows now reference Interest IRIs,
#      not pc: topic IRIs directly. Pipelines must materialize Interest
#      instances with gufo:inheresIn (Person) and gufo:externallyDependsOn
#      (pc: topic) at registration time.
#
################################################################################
# OPEN FLAGS (for human review)
################################################################################
# F1 - If any view-side sub-bucket should be assertable as a data value, give
#      it a skos:prefLabel. Current sub-buckets carry rdfs:label only.
################################################################################
