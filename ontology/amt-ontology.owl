<owl:Ontology rdf:about="http://amt.org/ontology"/>

<owl:ObjectProperty rdf:about="#hasCapability">
  <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasSpecification">
  <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasUser">
  <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <owl:inverseOf rdf:resource="#uses"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#uses">
  <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <owl:inverseOf rdf:resource="#hasUser"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasIMTSRegistrationUser">
  <rdfs:subPropertyOf rdf:resource="#hasUser"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#IMTSRegistrationUses">
  <rdfs:subPropertyOf rdf:resource="#uses"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasIMTSExhibitorRegistrationUser">
  <rdfs:subPropertyOf rdf:resource="#hasIMTSRegistrationUser"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasIMTSVisitorRegistrationUser">
  <rdfs:subPropertyOf rdf:resource="#hasIMTSRegistrationUser"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#IMTSExhibitorRegistrationUses">
  <rdfs:subPropertyOf rdf:resource="#IMTSRegistrationUses"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#IMTSVisitorRegistrationUses">
  <rdfs:subPropertyOf rdf:resource="#IMTSRegistrationUses"/>
</owl:ObjectProperty>

