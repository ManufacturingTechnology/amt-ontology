  <rdf:Description rdf:nodeID="n0ebd1d9309b94bc4a96ba0a86a3bbaacb1">
    <sh:select>
            PREFIX im:      &lt;http://ontology.amt.org/im#&gt;
            PREFIX amtmeta: &lt;http://ontology.amt.org/meta#&gt;
            PREFIX rdfs:    &lt;http://www.w3.org/2000/01/rdf-schema#&gt;
            SELECT $this ?value WHERE {
                $this im:belongsTo ?value .
                FILTER NOT EXISTS {
                    ?bucket amtmeta:groups+ ?value ;
                            rdfs:isDefinedBy &lt;http://ontology.amt.org/views/industries&gt; .
                }
            }
        </sh:select>
    <sh:message>Industry '{?value}' is not in the industries view's allowed set.</sh:message>
    <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLConstraint"/>
  </rdf:Description>
