  <rdf:Description rdf:nodeID="n39cec9e839f14745a9635f8c5e276f85b1">
    <sh:select>
            PREFIX im:      &lt;http://ontology.amt.org/im#&gt;
            PREFIX gufo:    &lt;http://purl.org/nemo/gufo#&gt;
            PREFIX amtmeta: &lt;http://ontology.amt.org/meta#&gt;
            PREFIX rdfs:    &lt;http://www.w3.org/2000/01/rdf-schema#&gt;
            SELECT $this ?value WHERE {
                $this    im:hasProductCategory     ?offering .
                ?offering gufo:externallyDependsOn ?value .
                FILTER NOT EXISTS {
                    ?bucket amtmeta:groups+ ?value ;
                            rdfs:isDefinedBy &lt;http://ontology.amt.org/views/exhibitor&gt; .
                }
            }
        </sh:select>
    <sh:message>Product category topic '{?value}' is not in the exhibitor view's allowed set.</sh:message>
    <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLConstraint"/>
  </rdf:Description>
