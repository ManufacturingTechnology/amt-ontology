  <rdf:Description rdf:nodeID="nb63b5f33bdb240569db8f0c6b9716134b1">
    <sh:select>
            PREFIX im:      &lt;http://ontology.amt.org/im#&gt;
            PREFIX gufo:    &lt;http://purl.org/nemo/gufo#&gt;
            PREFIX amtmeta: &lt;http://ontology.amt.org/meta#&gt;
            PREFIX rdfs:    &lt;http://www.w3.org/2000/01/rdf-schema#&gt;
            SELECT $this ?value WHERE {
                $this    im:hasInterest            ?interest .
                ?interest gufo:externallyDependsOn ?value .
                FILTER NOT EXISTS {
                    ?bucket amtmeta:groups+ ?value ;
                            rdfs:isDefinedBy &lt;http://ontology.amt.org/views/visitor&gt; .
                }
            }
        </sh:select>
    <sh:message>Interest topic '{?value}' is not in the visitor view's allowed set.</sh:message>
    <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLConstraint"/>
  </rdf:Description>
