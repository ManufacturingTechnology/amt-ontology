  <rdf:Description rdf:about="http://ontology.amt.org/im#hasProductCategory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment>Connects an ExhibitorRecord to a materialized im:ProductCategory instance (an ExtrinsicMode of the exhibiting Company, externally depending on a pc: topic). Value space and catalog-grade check defined by exhibitor_view:ExhibitorOfferingShape composed with amtmeta:CatalogValueShape, applied to the ProductCategory's gufo:externallyDependsOn topic.</rdfs:comment>
    <rdfs:domain rdf:resource="http://ontology.amt.org/im#ExhibitorRecord"/>
    <rdfs:range rdf:resource="http://ontology.amt.org/im#ProductCategory"/>
    <rdfs:label>has product category</rdfs:label>
  </rdf:Description>
